# App
APP_NAME=meal-recommender
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Solver
SOLVER_TIMEOUT_SECONDS=5.0
SOLVER_NUM_WORKERS=4
CALORIE_DELTA=100
NO_REPEAT_DAYS=2

# Objective weights
WEIGHT_FRIDGE=3
WEIGHT_EXPIRY=5
WEIGHT_DIVERSITY=2
WEIGHT_SHOPPING_PENALTY=3
EXPIRY_WINDOW_DAYS=7

# Data folder (bundled JSON files)
DATA_DIR=./data

# Limits
MAX_INGREDIENT_CLASSES=250
